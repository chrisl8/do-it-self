# Whitelist approach: ignore everything at the root, then un-ignore platform files.
# Container directories are managed by the module system (see docs/MODULES.md)
# and are not tracked in the platform repo.

# Ignore everything at root
/*

# Platform directories
!scripts/
!web-admin/
!docs/

# Host utilities (not containers)
!actual-budget-sync/
!borgbackup/

# Platform files
!container-registry.yaml
!module-catalog.yaml
!.gitignore
!.shellcheckrc
!CLAUDE.md
!AGENTS.md
!README.md
!PORTABILITY_ISSUES.md
!LICENSE

# IDE/editor config
!.vscode/
.idea/

# --- Ignores within platform directories ---

# Runtime state that can appear in any directory
tailscale-state/
.env

# Node.js
actual-budget-sync/node_modules/
actual-budget-sync/package-lock.json
scripts/node_modules/
scripts/package-lock.json
web-admin/**/node_modules/

# Scripts runtime config
scripts/healthcheck.conf
scripts/excluded_devices.conf
scripts/post-startup-hook.sh

# Module system runtime
installed-modules.yaml
.modules/

# User config
user-config.yaml
