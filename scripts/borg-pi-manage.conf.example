# borg-pi-manage.conf — neuromancer-side management of the backup Pi
# Sourced by ~/containers/scripts/borg-pi-manage.sh
#
# This file is hand-edited (not generated by the web admin). Copy this
# .example to borg-pi-manage.conf, fill in the URLs + secret keys, and add
# borg-pi-manage.sh invocations to chrisl8's user crontab.

# ── Connection ───────────────────────────────────────────────────
PI_HOST="backup-pi"
PI_USER="borg"
PI_SSH_KEY="$HOME/.ssh/borg-pi-mgmt"

# ── Logging / locking ────────────────────────────────────────────
LOG_FILE="$HOME/logs/borg-pi-manage.log"
LOCK_FILE="/tmp/borg-pi-manage.lock"

# ── Healthchecks.io ──────────────────────────────────────────────
#
# ONE URL for everything. All four operations (freshness + restore-test, for
# both clients) ping the same check:
#
#   - Success → bare URL, resets the deadman.
#   - Failure → URL/fail with a "<client>: <reason>" payload telling you
#     which client and which axis failed.
#
# The deadman period at HC.io should be ~25h (slightly longer than the daily
# freshness cron) so a one-time skip doesn't flap. Recommended: enable
# "don't auto-resolve from /fail" on the check so a transient restore-test
# failure stays visible until you ack it, even after the next daily success
# ping comes through.
#
# Leave empty to skip all HC.io pings entirely (operation still runs, log
# still records, just no external alerting).
HC_URL=""

# ── Clients ──────────────────────────────────────────────────────
#
# Each entry has six pipe-separated fields:
#   name | repo_path_on_pi | freshness_hours
#        | infisical_passphrase_key | restore_test_path | expected_content
#
# Pipe ('|') separators so empty fields don't silently shift positions.
# Surrounding whitespace within each field is trimmed.
#
# - name: matches Pi's CLIENTS list (lowercase, [a-z0-9-]+).
# - repo_path_on_pi: from Pi's /etc/backup-pi.conf CLIENT_<NAME>_REPO_PATH.
# - freshness_hours: alert if last archive is older than this.
# - infisical_passphrase_key: Infisical secret name under INFISICAL_PATH that
#     holds the BORG_PASSPHRASE for this client's REMOTE repo (on the Pi).
# - restore_test_path: path within the latest archive to extract+verify.
#     `etc/hostname` is a good choice — always present, tiny, known content.
# - expected_content: substring that must appear in the extracted file.
CLIENTS_MGMT=(
    "neuromancer | /mnt/backup/borg            | 48 | BORG_REMOTE_PASSPHRASE            | etc/hostname | neuromancer"
    "wintermute  | /mnt/backup/borg-wintermute | 48 | BORG_REMOTE_PASSPHRASE_WINTERMUTE | etc/hostname | wintermute"
)

# ── Infisical ────────────────────────────────────────────────────
# Path under which the passphrase secrets live. The infisical_passphrase_key
# above is looked up at this path.
INFISICAL_PATH="/borgbackup"
