# backup-coverage-audit.conf — neuromancer's coverage-audit settings.
# Sourced by ~/containers/scripts/backup-coverage-audit.sh.
# Copy this .example to backup-coverage-audit.conf before first run
# (script bootstraps it automatically on first invocation).

# Where the borg config lives. On neuromancer this is the bash-sourced
# borg-backup.conf that borg-backup.sh also uses; on wintermute set this
# to scripts/borgmatic-config-adapter.sh which translates borgmatic's
# YAML config into the same shell variables (BORG_BACKUP_PATHS array +
# BORG_EXCLUDE_FILE). Leaving this unset defaults to the neuromancer
# path for backwards compatibility.
# BORG_CONFIG_SOURCE="$HOME/containers/scripts/borg-backup.conf"

# Where the rendered JSON report lands. The web admin watches the
# parent directory for one report per host: <hostname>.json. Each host
# (neuromancer locally, wintermute via push) writes its own file; the
# multi-host UI discovers them all.
REPORT_FILE="$HOME/logs/coverage-reports/$(hostname).json"

# Optional: push the report to a central web-admin host after generating
# it. Set this on remote hosts (e.g. wintermute) to ship the report to
# neuromancer's coverage-reports dir so it appears in the web admin's
# host tabs. Format: rsync destination spec.
#   COVERAGE_REPORT_PUSH_DEST="chrisl8@neuromancer:/home/chrisl8/logs/coverage-reports/$(hostname).json"
#   COVERAGE_REPORT_PUSH_KEY="$HOME/.ssh/coverage-push"
# See docs/WINTERMUTE_COVERAGE_SETUP.md for the SSH key bootstrap.

# Where user acknowledgements live. Web admin's "Acknowledge" button
# appends here; the audit script reads it on each run to suppress
# repeated nagging on paths the user has consciously decided to skip.
ACK_FILE="$HOME/containers/scripts/backup-coverage-acks.json"

# Where the per-pattern exclude-match cache lives. Refreshed at most
# once per EXCLUDE_MATCHES_MAX_AGE_HOURS — the underlying walk is a
# ~4-minute filesystem traversal, far too heavy for the hourly cron.
# Patterns change rarely, so daily-ish freshness is plenty to catch
# the silent-overreach class of bug (jellyfin home_videos, Nextcloud
# Documents — see scripts/check-exclude-matches.py docstring).
EXCLUDE_MATCHES_FILE="$HOME/logs/backup-exclude-matches.json"
EXCLUDE_MATCHES_MAX_AGE_HOURS=23

# ── Candidate roots ──────────────────────────────────────────────
# Each entry: <root_path>|<depth>
#   root_path: top-level location to inspect
#   depth: how deep to descend before deciding (1 = immediate children,
#          2 = grandchildren). "Partial" entries auto-descend one more
#          level beyond their depth so subdir drift is surfaced even at
#          depth 1.
#
# /etc treated as a single entry (depth 0) — borg backs up the whole
# tree, so we check coverage at that root level only.
CANDIDATE_ROOTS=(
    "/home|1"
    "/mnt|2"
    "/root|1"
    "/opt|1"
    "/srv|1"
    "/etc|0"
)
